# ── Discord ────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_APP_ID=
DISCORD_GUILD_ID=

# ── GitHub App (NOT a Personal Access Token) ───────────────
GITHUB_APP_ID=
# Private key — pick ONE:
#  - a path to the .pem file (recommended for Docker/Portainer: mount the file)
GITHUB_APP_PRIVATE_KEY_FILE=
#  - OR the PEM inline, on one line with literal \n
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Webhook server ─────────────────────────────────────────
PORT=3000
WEBHOOK_PATH=/github/webhook

# ── Database (SQLite by default, PostgreSQL optional) ──────
DATABASE_URL="file:./prisma/dev.db"

# ── Runtime ────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
CONFIG_PATH=./config.yaml

# ── Deployment (docker-compose.deploy.yml) ─────────────────
# The image built by CI. In Docker the DATABASE_URL is overridden to
# file:/data/prod.db (a persisted volume) — no need to set it here.
BOT_IMAGE=ghcr.io/jordima/discord-forum-issues-bot:latest
